-- Scalar function for revenue segmentation
CREATE OR REPLACE FUNCTION analytics.fn_total_revenue_range(
    p_total_revenue numeric(10,2)
)
RETURNS TEXT
LANGUAGE sql
AS $$
    SELECT 
		CASE
			WHEN p_total_revenue <= 120.0 THEN 'Low'
			WHEN p_total_revenue <= 200.0 THEN 'Medium'
			ELSE 'High'
		END AS total_revenue_range;
$$;

-- Materialized view of total revenue by product
CREATE MATERIALIZED VIEW analytics.total_revenue_by_product AS
SELECT
	p.product_id,
	category,
	product_name,
	SUM(quantity * price) AS total_revenue,
	fn_total_revenue_range(SUM(quantity * price)) AS revenue_range
FROM analytics.order_items oi
LEFT JOIN analytics.products p ON oi.product_id = p.product_id
GROUP BY
	p.product_id,
	product_name,
	category
ORDER BY total_revenue DESC;

-- Price updating procedure
CREATE OR REPLACE PROCEDURE analytics.sp_update_price (
    p_product_id INT,
    p_price numeric(10,2)
)
LANGUAGE plpgsql
AS $$
BEGIN
	UPDATE analytics.products
	SET price = p_price
	WHERE product_id = p_product_id;

	IF NOT FOUND THEN
	RAISE EXCEPTION 'Product % not found', p_product_id;
	END IF;

	CREATE INDEX IF NOT EXISTS idx_revenue_by_product_id ON analytics.total_revenue_by_product(product_id);

	REFRESH MATERIALIZED VIEW analytics.total_revenue_by_product;
	
END;
$$;

CALL analytics.sp_update_price(3, 12.99);
CALL analytics.sp_update_price(2, 8.65);
